// SKILL-IOS (P7 #292) — common build settings shared by all configs.
//
// Pinned to ios-arm64.yaml min_os_version. Bumping below the platform
// floor would break StoreKit 2 (iOS 16+ baseline).

IPHONEOS_DEPLOYMENT_TARGET = 16.0
TARGETED_DEVICE_FAMILY = 1,2
PRODUCT_BUNDLE_IDENTIFIER = com.limit5.mapar
PRODUCT_NAME = MapAR

SWIFT_VERSION = 5.9
SWIFT_TREAT_WARNINGS_AS_ERRORS = YES
SWIFT_STRICT_CONCURRENCY = complete

ENABLE_BITCODE = NO
ENABLE_USER_SCRIPT_SANDBOXING = YES
SUPPORTS_MACCATALYST = NO

ARCHS = arm64
ONLY_ACTIVE_ARCH = $(BOOL_DEBUG)

// Privacy manifest path; required by Apple's 2024 policy.
INFOPLIST_KEY_NSPrivacyManifestPath = $(SRCROOT)/App/Resources/PrivacyInfo.xcprivacy
